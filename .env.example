# Runtime connection used by the application. Keep the database name distinct
# from the test database below.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/seatflow

# Direct PostgreSQL connection used by Prisma migrations. Providers with a
# pooled runtime URL should put their non-pooled URL here. Local development can
# use the same server and database as DATABASE_URL.
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/seatflow

# Optional Prisma Migrate shadow database. Only set this when your direct
# database user cannot create a temporary shadow database. It must be isolated.
# SHADOW_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/seatflow_shadow

# Dedicated disposable database used only by integration tests.
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/seatflow_test

# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
BETTER_AUTH_URL=http://localhost:3000

# Public origin used for metadata and browser-visible absolute URLs.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Redis is a transport and BullMQ backend only. PostgreSQL remains authoritative
# for availability, ownership, expiry, and all allocation decisions. Use rediss://
# with credentials supplied by your secret manager in production.
REDIS_URL=redis://127.0.0.1:6379
REDIS_STREAM_PREFIX=seatflow:development
REDIS_WORKER_ID=seatflow-local

# Separate Socket.IO gateway origin exposed to browser clients.
NEXT_PUBLIC_REALTIME_URL=http://localhost:3001

# Phase 5A payment provider. LOCAL_SIGNED is deterministic and strictly for
# development/test verification; application startup rejects it in production.
# Generate a dedicated local secret with: openssl rand -base64 48
PAYMENT_PROVIDER=LOCAL_SIGNED
LOCAL_PAYMENT_WEBHOOK_SECRET=replace-with-at-least-32-random-characters
# PAYMENT_WEBHOOK_MAX_BYTES=65536
# Production requires PAYMENT_PROVIDER=EXTERNAL and a reviewed external adapter.

# Phase 5B ticket credentials are opaque HMAC-derived values. Generate a
# dedicated secret (never reuse auth, payment, database, or Redis credentials).
TICKET_CREDENTIAL_SECRET=replace-with-at-least-32-random-characters
# TICKET_ENTRY_EARLY_MINUTES=120
# TICKET_ENTRY_LATE_MINUTES=240
# TICKET_DOWNLOAD_GRANT_TTL_MINUTES=10
# TICKET_SCAN_MAX_BYTES=2048
# TICKET_SCAN_RATE_LIMIT_PER_MINUTE=120
# TICKET_ISSUANCE_BATCH_SIZE=100
# TICKET_ISSUANCE_MAX_ATTEMPTS=8
# TICKET_ISSUANCE_BACKOFF_BASE_MS=1000
# TICKET_ISSUANCE_BACKOFF_MAX_MS=300000

# Deterministic local mail capture. LOCAL_FILE never sends external email and
# is rejected in production. A reviewed external adapter is a deployment gate.
NOTIFICATION_PROVIDER=LOCAL_FILE
LOCAL_EMAIL_CAPTURE_DIR=tmp/seatflow-mail
# NOTIFICATION_DISPATCH_BATCH_SIZE=100
# NOTIFICATION_DISPATCH_MAX_ATTEMPTS=8
# NOTIFICATION_DISPATCH_BACKOFF_BASE_MS=1000
# NOTIFICATION_DISPATCH_BACKOFF_MAX_MS=300000

# Optional bounded Phase 4B worker tuning.
# OUTBOX_DISPATCH_BATCH_SIZE=100
# OUTBOX_DISPATCH_MAX_ATTEMPTS=8
# OUTBOX_DISPATCH_BACKOFF_BASE_MS=1000
# OUTBOX_DISPATCH_BACKOFF_MAX_MS=300000
# REDIS_STREAM_MAX_LENGTH=100000
# REDIS_EVENT_DEDUP_TTL_SECONDS=604800
# HOLD_EXPIRY_QUEUE_NAME=seatflow-hold-expiry
# HOLD_EXPIRY_SWEEP_INTERVAL_MS=30000
# HOLD_EXPIRY_JOB_ATTEMPTS=5
# REALTIME_GATEWAY_PORT=3001
# REALTIME_MAX_CONNECTIONS_PER_IP=10

# Optional Phase 4A hold tuning. Defaults are 10 minutes, 8 seats, and 100
# expired holds per sweep batch. Server validation constrains every override.
# SEAT_HOLD_DURATION_MINUTES=10
# SEAT_HOLD_MAX_SEATS=8
# SEAT_HOLD_SWEEP_BATCH_SIZE=100

# --- Phase 5C1: observability, abuse controls, and deployment gates ---------
# All settings below are optional and default to safe values.

# Structured logging. Production emits one JSON record per line.
SEATFLOW_SERVICE_NAME=seatflow-web
LOG_LEVEL=info
# Non-secret label distinguishing worker instances in heartbeats, e.g. "dispatcher-1".
# SEATFLOW_INSTANCE_LABEL=default
# SEATFLOW_RELEASE_VERSION=

# Trusted proxy. `none` ignores forwarding headers entirely and is the safe
# default for a directly reachable process. Choose deliberately: too many hops
# collapses every client into one rate-limit bucket, too few lets a caller
# inject an address by prepending to X-Forwarded-For.
#   none            - reached directly; ignore X-Forwarded-For
#   trusted-hop     - N reverse proxies append to X-Forwarded-For
#   platform-header - one platform header is authoritative
TRUSTED_PROXY_MODE=none
TRUSTED_PROXY_HOP_COUNT=1
# Only set for platform-header mode, e.g. cf-connecting-ip or true-client-ip.
# TRUSTED_PROXY_HEADER=cf-connecting-ip

# Distributed abuse controls. Redis-backed when REDIS_URL is reachable, with a
# process-local fallback. Disabling this is rejected by production:check.
RATE_LIMIT_ENABLED=true

# A worker whose heartbeat is older than this is reported stale by readiness.
WORKER_HEARTBEAT_STALE_SECONDS=180

# Readiness warns (never fails) above these outbox thresholds.
READINESS_MAX_OUTBOX_BACKLOG=500
READINESS_MAX_OUTBOX_AGE_SECONDS=300

# Deployment gates enforced by `npm run production:check` with live probes.
DEPLOY_MAX_DEAD_LETTERS=0
DEPLOY_MAX_PAID_UNFULFILLED=0

# Security headers. HSTS is emitted only over HTTPS.
SECURITY_HEADERS_ENABLED=true
SECURITY_HSTS_MAX_AGE_SECONDS=31536000

# Every worker process that must be running before production traffic is
# enabled. production:check fails when any is absent.
SEATFLOW_DECLARED_WORKERS=INVENTORY_OUTBOX_DISPATCHER,HOLD_EXPIRY_WORKER,REALTIME_GATEWAY,TICKET_ISSUANCE_DISPATCHER,NOTIFICATION_DISPATCHER,PAYMENT_RECONCILIATION

# Backup and restore tooling. Backups contain complete customer, payment, and
# ticket data: keep them outside the repository and under secret-grade control.
# PG_BIN_DIR=/path/to/postgresql/bin
# BACKUP_DIR=/secure/backups/seatflow
# BACKUP_VERIFY_DATABASE_URL=postgresql://user@localhost:5432/seatflow_verify

# Load harness HTTP target. Loopback only unless --allow-non-local is passed.
# LOAD_TEST_BASE_URL=http://localhost:3000
