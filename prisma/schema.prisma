generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum PlatformRole {
  USER
  ADMIN
}

enum OrganizationKind {
  ORGANIZER
  VENUE_OPERATOR
}

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
}

enum VenueStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum SpaceType {
  CINEMA
  THEATRE
  CONCERT_HALL
  STADIUM
  ARENA
  GENERAL
}

enum SpaceStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum SeatMapStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum SeatType {
  STANDARD
  ACCESSIBLE
  COMPANION
  PREMIUM
}

enum SeatState {
  ACTIVE
  BLOCKED
}

enum VenueAccessGrantStatus {
  ACTIVE
  REVOKED
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  ARCHIVED
}

enum EventCategory {
  CONCERT
  CINEMA
  THEATRE
  SPORT
  OTHER
}

enum EventSessionStatus {
  DRAFT
  SCHEDULED
  ON_SALE
  SALES_PAUSED
  CANCELLED
  COMPLETED
}

enum Currency {
  AZN
  EUR
  GBP
  USD
}

enum SeatInventoryState {
  AVAILABLE
  HELD
  BOOKED
}

enum SeatHoldStatus {
  ACTIVE
  RELEASED
  EXPIRED
  CONVERTED
}

enum InventoryEventType {
  INVENTORY_MATERIALIZED
  HOLD_CREATED
  HOLD_RELEASED
  HOLD_EXPIRED
  SESSION_CANCELLED
  CHECKOUT_CREATED
  PAYMENT_INTENT_CREATED
  PAYMENT_SUCCEEDED
  PAYMENT_FAILED
  INVENTORY_BOOKED
  BOOKING_CONFIRMED
  PAYMENT_REQUIRES_REVIEW
}

enum CheckoutOrderStatus {
  PENDING
  PAYMENT_PENDING
  PAID
  FULFILLED
  FAILED
  CANCELLED
  EXPIRED
  PAID_UNFULFILLED
  REQUIRES_REVIEW
}

enum PaymentProviderName {
  LOCAL_SIGNED
  EXTERNAL
}

enum PaymentAttemptStatus {
  CREATED
  PENDING
  SUCCEEDED
  FAILED
  CANCELLED
  REQUIRES_REVIEW
}

enum PaymentWebhookSignatureStatus {
  VERIFIED
  INVALID
}

enum PaymentWebhookProcessingStatus {
  RECEIVED
  PROCESSED
  REQUIRES_REVIEW
  FAILED
}

enum BookingStatus {
  CONFIRMED
}

enum TicketStatus {
  ACTIVE
  REVOKED
  USED
}

enum TicketCredentialStatus {
  ACTIVE
  REVOKED
  REPLACED
  USED
}

enum TicketRedemptionOutcome {
  ACCEPTED
  ALREADY_USED
  REVOKED
  INVALID
  WRONG_SESSION
  TOO_EARLY
  TOO_LATE
  SESSION_CANCELLED
  UNAUTHORIZED_SCANNER
}

enum TicketDownloadGrantPurpose {
  BOOKING_PDF
}

enum TicketIssuanceRequestStatus {
  PENDING
  COMPLETED
  DEAD_LETTER
}

enum TicketAuditAction {
  ISSUED
  CREDENTIAL_ROTATED
  REVOKED
}

enum NotificationType {
  BOOKING_TICKETS_READY
  CREDENTIAL_ROTATED
  TICKET_REVOKED
}

enum NotificationOutboxStatus {
  PENDING
  PROCESSED
  DEAD_LETTER
}

enum NotificationProviderName {
  LOCAL_FILE
  EXTERNAL
}

enum NotificationDeliveryStatus {
  SUCCEEDED
  RETRYABLE_FAILURE
  PERMANENT_FAILURE
  TIMEOUT
}

model User {
  id            String       @id @default(cuid())
  name          String
  email         String       @unique
  emailVerified Boolean      @default(false)
  image         String?
  platformRole  PlatformRole @default(USER)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  accounts                 Account[]
  sessions                 Session[]
  memberships              Membership[]
  venueAccessGrantsGranted VenueAccessGrant[]      @relation("VenueAccessGrantedBy")
  venueAccessGrantsRevoked VenueAccessGrant[]      @relation("VenueAccessRevokedBy")
  seatHolds                SeatHold[]
  checkoutOrders           CheckoutOrder[]
  bookings                 Booking[]
  tickets                  Ticket[]                @relation("TicketOwner")
  ticketsRevoked           Ticket[]                @relation("TicketRevokedBy")
  ticketRedemptions        TicketRedemptionEvent[] @relation("TicketRedemptionScanner")
  ticketDownloadGrants     TicketDownloadGrant[]
  ticketAuditEvents        TicketAuditEvent[]      @relation("TicketAuditActor")
  notificationOutbox       NotificationOutbox[]    @relation("NotificationRecipient")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@index([expiresAt])
}

model Organization {
  id        String           @id @default(cuid())
  name      String
  slug      String           @unique
  kind      OrganizationKind
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  memberships                Membership[]
  venues                     Venue[]
  events                     Event[]                 @relation("OrganizerEvents")
  organizerVenueAccessGrants VenueAccessGrant[]      @relation("OrganizerVenueAccess")
  operatorVenueAccessGrants  VenueAccessGrant[]      @relation("OperatorVenueAccess")
  checkoutOrders             CheckoutOrder[]
  bookings                   Booking[]
  tickets                    Ticket[]
  ticketRedemptions          TicketRedemptionEvent[]

  @@index([kind])
}

model Membership {
  id             String         @id @default(cuid())
  userId         String
  organizationId String
  role           MembershipRole @default(MEMBER)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId, role])
}

model Venue {
  id             String      @id @default(cuid())
  organizationId String
  name           String
  slug           String
  description    String?
  addressLine1   String
  addressLine2   String?
  city           String
  countryCode    String      @db.Char(2)
  postalCode     String?
  timeZone       String
  status         VenueStatus @default(DRAFT)
  archivedAt     DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organization  Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  spaces        Space[]
  accessGrants  VenueAccessGrant[]
  eventSessions EventSession[]

  @@unique([organizationId, slug])
  @@index([organizationId, status])
  @@index([organizationId, name])
}

model Space {
  id          String      @id @default(cuid())
  venueId     String
  name        String
  slug        String
  description String?
  type        SpaceType   @default(GENERAL)
  status      SpaceStatus @default(DRAFT)
  archivedAt  DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  venue         Venue          @relation(fields: [venueId], references: [id], onDelete: Restrict)
  seatMaps      SeatMap[]
  eventSessions EventSession[]

  @@unique([venueId, slug])
  @@index([venueId, status])
  @@index([venueId, name])
}

model SeatMap {
  id              String        @id @default(cuid())
  spaceId         String
  sourceSeatMapId String?
  name            String
  version         Int
  status          SeatMapStatus @default(DRAFT)
  publishedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  space         Space          @relation(fields: [spaceId], references: [id], onDelete: Restrict)
  sourceSeatMap SeatMap?       @relation("SeatMapSource", fields: [sourceSeatMapId], references: [id], onDelete: SetNull)
  clones        SeatMap[]      @relation("SeatMapSource")
  sections      SeatSection[]
  eventSessions EventSession[]

  @@unique([spaceId, version])
  @@index([spaceId, status])
  @@index([sourceSeatMapId])
}

model SeatSection {
  id           String   @id @default(cuid())
  seatMapId    String
  name         String
  code         String
  displayOrder Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  seatMap                   SeatMap                 @relation(fields: [seatMapId], references: [id], onDelete: Cascade)
  rows                      SeatRow[]
  sessionPricingAssignments SessionSectionPricing[]
  sessionInventory          SessionSeatInventory[]
  checkoutOrderItems        CheckoutOrderItem[]
  bookingSeats              BookingSeat[]

  @@unique([seatMapId, code])
  @@index([seatMapId, displayOrder])
}

model SeatRow {
  id           String   @id @default(cuid())
  sectionId    String
  label        String
  displayOrder Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  section SeatSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  seats   Seat[]

  @@unique([sectionId, label])
  @@index([sectionId, displayOrder])
}

model Seat {
  id           String    @id @default(cuid())
  rowId        String
  label        String
  displayOrder Int
  x            Int
  y            Int
  type         SeatType  @default(STANDARD)
  state        SeatState @default(ACTIVE)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  row                SeatRow                @relation(fields: [rowId], references: [id], onDelete: Cascade)
  sessionInventory   SessionSeatInventory[]
  checkoutOrderItems CheckoutOrderItem[]
  bookingSeats       BookingSeat[]

  @@unique([rowId, label])
  @@index([rowId, displayOrder])
  @@index([type, state])
}

model VenueAccessGrant {
  id                      String                 @id @default(cuid())
  organizerOrganizationId String
  operatorOrganizationId  String
  venueId                 String
  status                  VenueAccessGrantStatus @default(ACTIVE)
  grantedByUserId         String?
  revokedByUserId         String?
  createdAt               DateTime               @default(now()) @db.Timestamptz(3)
  updatedAt               DateTime               @updatedAt @db.Timestamptz(3)
  revokedAt               DateTime?              @db.Timestamptz(3)

  organizerOrganization Organization @relation("OrganizerVenueAccess", fields: [organizerOrganizationId], references: [id], onDelete: Restrict)
  operatorOrganization  Organization @relation("OperatorVenueAccess", fields: [operatorOrganizationId], references: [id], onDelete: Restrict)
  venue                 Venue        @relation(fields: [venueId], references: [id], onDelete: Restrict)
  grantedByUser         User?        @relation("VenueAccessGrantedBy", fields: [grantedByUserId], references: [id], onDelete: SetNull)
  revokedByUser         User?        @relation("VenueAccessRevokedBy", fields: [revokedByUserId], references: [id], onDelete: SetNull)

  @@index([organizerOrganizationId, status])
  @@index([operatorOrganizationId, status])
  @@index([venueId, status])
  @@index([grantedByUserId])
  @@index([revokedByUserId])
}

model Event {
  id                      String        @id @default(cuid())
  organizerOrganizationId String
  title                   String
  slug                    String
  publicSlug              String        @unique
  shortDescription        String
  description             String
  category                EventCategory
  imagePath               String?
  status                  EventStatus   @default(DRAFT)
  preArchiveStatus        EventStatus?
  createdAt               DateTime      @default(now()) @db.Timestamptz(3)
  updatedAt               DateTime      @updatedAt @db.Timestamptz(3)
  publishedAt             DateTime?     @db.Timestamptz(3)
  cancelledAt             DateTime?     @db.Timestamptz(3)
  archivedAt              DateTime?     @db.Timestamptz(3)

  organizerOrganization Organization            @relation("OrganizerEvents", fields: [organizerOrganizationId], references: [id], onDelete: Restrict)
  sessions              EventSession[]
  checkoutOrders        CheckoutOrder[]
  bookings              Booking[]
  tickets               Ticket[]
  ticketRedemptions     TicketRedemptionEvent[]

  @@unique([organizerOrganizationId, slug])
  @@index([organizerOrganizationId, status])
  @@index([organizerOrganizationId, createdAt])
  @@index([status, publishedAt])
  @@index([category, status])
}

model EventSession {
  id           String             @id @default(cuid())
  eventId      String
  venueId      String
  spaceId      String
  seatMapId    String
  startAt      DateTime           @db.Timestamptz(3)
  endAt        DateTime           @db.Timestamptz(3)
  salesStartAt DateTime           @db.Timestamptz(3)
  salesEndAt   DateTime           @db.Timestamptz(3)
  status       EventSessionStatus @default(DRAFT)
  createdAt    DateTime           @default(now()) @db.Timestamptz(3)
  updatedAt    DateTime           @updatedAt @db.Timestamptz(3)
  publishedAt  DateTime?          @db.Timestamptz(3)
  cancelledAt  DateTime?          @db.Timestamptz(3)

  event             Event                   @relation(fields: [eventId], references: [id], onDelete: Restrict)
  venue             Venue                   @relation(fields: [venueId], references: [id], onDelete: Restrict)
  space             Space                   @relation(fields: [spaceId], references: [id], onDelete: Restrict)
  seatMap           SeatMap                 @relation(fields: [seatMapId], references: [id], onDelete: Restrict)
  priceTiers        SessionPriceTier[]
  sectionPricing    SessionSectionPricing[]
  seatInventory     SessionSeatInventory[]
  seatHolds         SeatHold[]
  inventoryEvents   InventoryEventOutbox[]
  checkoutOrders    CheckoutOrder[]
  bookings          Booking[]
  bookingSeats      BookingSeat[]
  tickets           Ticket[]
  ticketRedemptions TicketRedemptionEvent[]

  @@index([eventId, status])
  @@index([eventId, startAt])
  @@index([venueId, startAt])
  @@index([spaceId, startAt, endAt])
  @@index([seatMapId])
  @@index([status, startAt])
}

model SessionPriceTier {
  id           String   @id @default(cuid())
  sessionId    String
  name         String
  code         String
  priceMinor   Int
  currency     Currency
  displayOrder Int
  description  String?
  createdAt    DateTime @default(now()) @db.Timestamptz(3)
  updatedAt    DateTime @updatedAt @db.Timestamptz(3)

  session            EventSession            @relation(fields: [sessionId], references: [id], onDelete: Restrict)
  sectionAssignments SessionSectionPricing[]
  sessionInventory   SessionSeatInventory[]
  checkoutOrderItems CheckoutOrderItem[]
  bookingSeats       BookingSeat[]

  @@unique([sessionId, code])
  @@index([sessionId, displayOrder])
  @@index([sessionId, currency])
}

model SessionSectionPricing {
  id          String   @id @default(cuid())
  sessionId   String
  sectionId   String
  priceTierId String
  createdAt   DateTime @default(now()) @db.Timestamptz(3)

  session   EventSession     @relation(fields: [sessionId], references: [id], onDelete: Restrict)
  section   SeatSection      @relation(fields: [sectionId], references: [id], onDelete: Restrict)
  priceTier SessionPriceTier @relation(fields: [priceTierId], references: [id], onDelete: Restrict)

  @@unique([sessionId, sectionId])
  @@index([sessionId])
  @@index([sectionId])
  @@index([priceTierId])
}

// Authoritative per-session sellable seat inventory materialized from an
// immutable published seat map. Price and currency are immutable snapshots.
// PostgreSQL is the single source of truth for availability and active holds.
model SessionSeatInventory {
  id            String             @id @default(cuid())
  sessionId     String
  seatId        String
  sectionId     String
  priceTierId   String
  priceMinor    Int
  currency      Currency
  state         SeatInventoryState @default(AVAILABLE)
  currentHoldId String?
  holdExpiresAt DateTime?          @db.Timestamptz(3)
  createdAt     DateTime           @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime           @updatedAt @db.Timestamptz(3)

  session            EventSession        @relation(fields: [sessionId], references: [id], onDelete: Restrict)
  seat               Seat                @relation(fields: [seatId], references: [id], onDelete: Restrict)
  section            SeatSection         @relation(fields: [sectionId], references: [id], onDelete: Restrict)
  priceTier          SessionPriceTier    @relation(fields: [priceTierId], references: [id], onDelete: Restrict)
  currentHold        SeatHold?           @relation("HoldCurrentInventory", fields: [currentHoldId], references: [id], onDelete: Restrict)
  holdItems          SeatHoldItem[]
  checkoutOrderItems CheckoutOrderItem[]
  bookingSeats       BookingSeat[]

  @@unique([sessionId, seatId])
  @@index([sessionId, state])
  @@index([currentHoldId])
  @@index([holdExpiresAt])
  @@index([seatId])
  @@index([priceTierId])
  @@index([sectionId])
}

// A server-owned, all-or-nothing temporary hold over one or more inventory
// seats within a single session. The public token is unguessable; internal ids
// are never exposed to other customers. Holds are historical and never deleted.
model SeatHold {
  id             String         @id @default(cuid())
  publicToken    String         @unique
  sessionId      String
  userId         String
  status         SeatHoldStatus @default(ACTIVE)
  idempotencyKey String
  expiresAt      DateTime       @db.Timestamptz(3)
  createdAt      DateTime       @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime       @updatedAt @db.Timestamptz(3)
  releasedAt     DateTime?      @db.Timestamptz(3)
  expiredAt      DateTime?      @db.Timestamptz(3)
  convertedAt    DateTime?      @db.Timestamptz(3)

  session          EventSession           @relation(fields: [sessionId], references: [id], onDelete: Restrict)
  user             User                   @relation(fields: [userId], references: [id], onDelete: Restrict)
  items            SeatHoldItem[]
  currentInventory SessionSeatInventory[] @relation("HoldCurrentInventory")
  checkoutOrder    CheckoutOrder?

  @@unique([sessionId, userId, idempotencyKey])
  @@index([status, expiresAt])
  @@index([userId, status])
  @@index([sessionId, status])
}

// One seat within a hold. Price and currency are copied from inventory at
// acquisition time, never supplied by the client, and preserved as history.
model SeatHoldItem {
  id          String   @id @default(cuid())
  holdId      String
  inventoryId String
  priceMinor  Int
  currency    Currency
  createdAt   DateTime @default(now()) @db.Timestamptz(3)

  hold      SeatHold             @relation(fields: [holdId], references: [id], onDelete: Restrict)
  inventory SessionSeatInventory @relation(fields: [inventoryId], references: [id], onDelete: Restrict)

  @@unique([holdId, inventoryId])
  @@index([inventoryId])
}

// Immutable, server-priced checkout created from exactly one customer hold.
// The public reference is unguessable and every ancestry field is protected by
// PostgreSQL constraints/triggers in the Phase 5A migration.
model CheckoutOrder {
  id                String              @id @default(cuid())
  publicReference   String              @unique
  userId            String
  organizationId    String
  eventId           String
  sessionId         String
  sourceHoldId      String              @unique
  status            CheckoutOrderStatus @default(PENDING)
  currency          Currency
  subtotalMinor     Int
  totalMinor        Int
  idempotencyKey    String
  checkoutExpiresAt DateTime            @db.Timestamptz(3)
  createdAt         DateTime            @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime            @updatedAt @db.Timestamptz(3)
  paidAt            DateTime?           @db.Timestamptz(3)
  fulfilledAt       DateTime?           @db.Timestamptz(3)
  failedAt          DateTime?           @db.Timestamptz(3)
  cancelledAt       DateTime?           @db.Timestamptz(3)
  expiredAt         DateTime?           @db.Timestamptz(3)
  safeFailureCode   String?
  version           Int                 @default(0)

  user            User                @relation(fields: [userId], references: [id], onDelete: Restrict)
  organization    Organization        @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  event           Event               @relation(fields: [eventId], references: [id], onDelete: Restrict)
  session         EventSession        @relation(fields: [sessionId], references: [id], onDelete: Restrict)
  sourceHold      SeatHold            @relation(fields: [sourceHoldId], references: [id], onDelete: Restrict)
  items           CheckoutOrderItem[]
  paymentAttempts PaymentAttempt[]
  booking         Booking?

  @@unique([userId, sourceHoldId, idempotencyKey])
  @@index([userId, createdAt])
  @@index([organizationId, status])
  @@index([eventId, status])
  @@index([sessionId, status])
  @@index([status, checkoutExpiresAt])
}

model CheckoutOrderItem {
  id          String   @id @default(cuid())
  orderId     String
  inventoryId String
  seatId      String
  sectionId   String
  priceTierId String
  seatLabel   String
  rowLabel    String
  sectionName String
  sectionCode String
  tierName    String
  tierCode    String
  priceMinor  Int
  currency    Currency
  createdAt   DateTime @default(now()) @db.Timestamptz(3)

  order     CheckoutOrder        @relation(fields: [orderId], references: [id], onDelete: Restrict)
  inventory SessionSeatInventory @relation(fields: [inventoryId], references: [id], onDelete: Restrict)
  seat      Seat                 @relation(fields: [seatId], references: [id], onDelete: Restrict)
  section   SeatSection          @relation(fields: [sectionId], references: [id], onDelete: Restrict)
  priceTier SessionPriceTier     @relation(fields: [priceTierId], references: [id], onDelete: Restrict)

  @@unique([orderId, inventoryId])
  @@unique([orderId, seatId])
  @@index([inventoryId])
  @@index([seatId])
  @@index([sectionId])
  @@index([priceTierId])
}

model PaymentAttempt {
  id                     String               @id @default(cuid())
  orderId                String
  provider               PaymentProviderName
  providerIntentId       String?
  providerIdempotencyKey String               @unique
  status                 PaymentAttemptStatus @default(CREATED)
  amountMinor            Int
  currency               Currency
  lastProviderStatus     String?
  safeFailureCode        String?
  createdAt              DateTime             @default(now()) @db.Timestamptz(3)
  updatedAt              DateTime             @updatedAt @db.Timestamptz(3)
  succeededAt            DateTime?            @db.Timestamptz(3)
  failedAt               DateTime?            @db.Timestamptz(3)
  cancelledAt            DateTime?            @db.Timestamptz(3)

  order         CheckoutOrder         @relation(fields: [orderId], references: [id], onDelete: Restrict)
  webhookEvents PaymentWebhookEvent[]

  @@unique([orderId, provider])
  @@unique([provider, providerIntentId])
  @@index([status, updatedAt])
}

model PaymentWebhookEvent {
  id                  String                         @id @default(cuid())
  provider            PaymentProviderName
  providerEventId     String
  eventType           String
  providerIntentId    String
  paymentAttemptId    String?
  normalizedStatus    PaymentAttemptStatus
  amountMinor         Int
  currency            Currency
  signatureStatus     PaymentWebhookSignatureStatus
  processingStatus    PaymentWebhookProcessingStatus @default(RECEIVED)
  receivedAt          DateTime                       @default(now()) @db.Timestamptz(3)
  processedAt         DateTime?                      @db.Timestamptz(3)
  providerOccurredAt  DateTime?                      @db.Timestamptz(3)
  attemptCount        Int                            @default(0)
  safeProcessingError String?
  payloadHash         String                         @db.Char(64)

  paymentAttempt PaymentAttempt? @relation(fields: [paymentAttemptId], references: [id], onDelete: Restrict)

  @@unique([provider, providerEventId])
  @@index([paymentAttemptId, receivedAt])
  @@index([processingStatus, receivedAt])
  @@index([provider, providerIntentId])
}

model Booking {
  id              String        @id @default(cuid())
  publicReference String        @unique
  orderId         String        @unique
  userId          String
  organizationId  String
  eventId         String
  sessionId       String
  status          BookingStatus @default(CONFIRMED)
  currency        Currency
  totalMinor      Int
  confirmedAt     DateTime      @db.Timestamptz(3)
  createdAt       DateTime      @default(now()) @db.Timestamptz(3)

  order           CheckoutOrder          @relation(fields: [orderId], references: [id], onDelete: Restrict)
  user            User                   @relation(fields: [userId], references: [id], onDelete: Restrict)
  organization    Organization           @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  event           Event                  @relation(fields: [eventId], references: [id], onDelete: Restrict)
  session         EventSession           @relation(fields: [sessionId], references: [id], onDelete: Restrict)
  seats           BookingSeat[]
  tickets         Ticket[]
  issuanceRequest TicketIssuanceRequest?
  downloadGrants  TicketDownloadGrant[]
  notifications   NotificationOutbox[]

  @@index([userId, confirmedAt])
  @@index([organizationId, confirmedAt])
  @@index([eventId, confirmedAt])
  @@index([sessionId, confirmedAt])
}

model BookingSeat {
  id          String   @id @default(cuid())
  bookingId   String
  inventoryId String   @unique
  sessionId   String
  seatId      String
  sectionId   String
  priceTierId String
  seatLabel   String
  rowLabel    String
  sectionName String
  sectionCode String
  tierName    String
  tierCode    String
  priceMinor  Int
  currency    Currency
  createdAt   DateTime @default(now()) @db.Timestamptz(3)

  booking   Booking              @relation(fields: [bookingId], references: [id], onDelete: Restrict)
  inventory SessionSeatInventory @relation(fields: [inventoryId], references: [id], onDelete: Restrict)
  session   EventSession         @relation(fields: [sessionId], references: [id], onDelete: Restrict)
  seat      Seat                 @relation(fields: [seatId], references: [id], onDelete: Restrict)
  section   SeatSection          @relation(fields: [sectionId], references: [id], onDelete: Restrict)
  priceTier SessionPriceTier     @relation(fields: [priceTierId], references: [id], onDelete: Restrict)
  ticket    Ticket?

  @@unique([bookingId, inventoryId])
  @@unique([sessionId, seatId])
  @@index([bookingId])
  @@index([sessionId])
  @@index([seatId])
  @@index([sectionId])
  @@index([priceTierId])
}

// One independently controlled admission ticket per confirmed booked seat.
// Public references are random; QR credentials are never stored in plaintext.
model Ticket {
  id                       String       @id @default(cuid())
  publicReference          String       @unique
  bookingId                String
  bookingSeatId            String       @unique
  userId                   String
  organizationId           String
  eventId                  String
  sessionId                String
  status                   TicketStatus @default(ACTIVE)
  issuedAt                 DateTime     @db.Timestamptz(3)
  revokedAt                DateTime?    @db.Timestamptz(3)
  revocationReason         String?
  revokedByUserId          String?
  lastCredentialRotationAt DateTime?    @db.Timestamptz(3)
  createdAt                DateTime     @default(now()) @db.Timestamptz(3)
  updatedAt                DateTime     @updatedAt @db.Timestamptz(3)

  booking          Booking                 @relation(fields: [bookingId], references: [id], onDelete: Restrict)
  bookingSeat      BookingSeat             @relation(fields: [bookingSeatId], references: [id], onDelete: Restrict)
  user             User                    @relation("TicketOwner", fields: [userId], references: [id], onDelete: Restrict)
  organization     Organization            @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  event            Event                   @relation(fields: [eventId], references: [id], onDelete: Restrict)
  session          EventSession            @relation(fields: [sessionId], references: [id], onDelete: Restrict)
  revokedByUser    User?                   @relation("TicketRevokedBy", fields: [revokedByUserId], references: [id], onDelete: Restrict)
  credentials      TicketCredential[]
  redemptionEvents TicketRedemptionEvent[]
  auditEvents      TicketAuditEvent[]
  notifications    NotificationOutbox[]

  @@index([bookingId])
  @@index([userId, issuedAt])
  @@index([organizationId, status])
  @@index([eventId, status])
  @@index([sessionId, status])
}

model TicketCredential {
  id                      String                 @id @default(cuid())
  ticketId                String
  version                 Int
  credentialHash          String                 @unique @db.Char(64)
  hashAlgorithm           String                 @default("HMAC-SHA256-V1")
  status                  TicketCredentialStatus @default(ACTIVE)
  issuedAt                DateTime               @db.Timestamptz(3)
  revokedAt               DateTime?              @db.Timestamptz(3)
  replacedAt              DateTime?              @db.Timestamptz(3)
  usedAt                  DateTime?              @db.Timestamptz(3)
  replacementCredentialId String?                @unique
  createdAt               DateTime               @default(now()) @db.Timestamptz(3)

  ticket                Ticket                  @relation(fields: [ticketId], references: [id], onDelete: Restrict)
  replacementCredential TicketCredential?       @relation("CredentialReplacement", fields: [replacementCredentialId], references: [id], onDelete: Restrict)
  replaces              TicketCredential?       @relation("CredentialReplacement")
  redemptionEvents      TicketRedemptionEvent[]

  @@unique([ticketId, version])
  @@index([ticketId, status])
}

model TicketRedemptionEvent {
  id                 String                  @id @default(uuid())
  ticketId           String?
  ticketCredentialId String?
  organizationId     String
  eventId            String
  sessionId          String
  scannerUserId      String
  outcome            TicketRedemptionOutcome
  scannedAt          DateTime                @db.Timestamptz(3)
  scannerIdentifier  String?
  rejectionReason    String?
  idempotencyKey     String?
  createdAt          DateTime                @default(now()) @db.Timestamptz(3)

  ticket       Ticket?           @relation(fields: [ticketId], references: [id], onDelete: Restrict)
  credential   TicketCredential? @relation(fields: [ticketCredentialId], references: [id], onDelete: Restrict)
  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  event        Event             @relation(fields: [eventId], references: [id], onDelete: Restrict)
  session      EventSession      @relation(fields: [sessionId], references: [id], onDelete: Restrict)
  scannerUser  User              @relation("TicketRedemptionScanner", fields: [scannerUserId], references: [id], onDelete: Restrict)

  @@unique([scannerUserId, idempotencyKey])
  @@index([ticketId, scannedAt])
  @@index([sessionId, scannedAt])
  @@index([organizationId, outcome, scannedAt])
}

model TicketDownloadGrant {
  id        String                     @id @default(uuid())
  bookingId String
  userId    String
  tokenHash String                     @unique @db.Char(64)
  purpose   TicketDownloadGrantPurpose @default(BOOKING_PDF)
  expiresAt DateTime                   @db.Timestamptz(3)
  usedAt    DateTime?                  @db.Timestamptz(3)
  revokedAt DateTime?                  @db.Timestamptz(3)
  createdAt DateTime                   @default(now()) @db.Timestamptz(3)

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Restrict)
  user    User    @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId, expiresAt])
  @@index([bookingId, createdAt])
}

model TicketIssuanceRequest {
  id           String                      @id @default(uuid())
  bookingId    String                      @unique
  status       TicketIssuanceRequestStatus @default(PENDING)
  availableAt  DateTime                    @default(now()) @db.Timestamptz(3)
  attemptCount Int                         @default(0)
  processedAt  DateTime?                   @db.Timestamptz(3)
  lastError    String?
  deadLetterAt DateTime?                   @db.Timestamptz(3)
  createdAt    DateTime                    @default(now()) @db.Timestamptz(3)
  updatedAt    DateTime                    @updatedAt @db.Timestamptz(3)

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Restrict)

  @@index([status, availableAt, createdAt])
}

model TicketAuditEvent {
  id          String            @id @default(uuid())
  ticketId    String
  actorUserId String?
  action      TicketAuditAction
  safeReason  String?
  createdAt   DateTime          @default(now()) @db.Timestamptz(3)

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Restrict)
  actor  User?  @relation("TicketAuditActor", fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([ticketId, createdAt])
  @@index([actorUserId, createdAt])
}

model NotificationOutbox {
  id               String                   @id @default(uuid())
  notificationType NotificationType
  recipientUserId  String
  bookingId        String?
  ticketId         String?
  templateVersion  Int                      @default(1)
  locale           String                   @default("en")
  payload          Json
  deduplicationKey String                   @unique
  status           NotificationOutboxStatus @default(PENDING)
  availableAt      DateTime                 @default(now()) @db.Timestamptz(3)
  attemptCount     Int                      @default(0)
  processedAt      DateTime?                @db.Timestamptz(3)
  lastError        String?
  deadLetterAt     DateTime?                @db.Timestamptz(3)
  createdAt        DateTime                 @default(now()) @db.Timestamptz(3)
  updatedAt        DateTime                 @updatedAt @db.Timestamptz(3)

  recipient        User                          @relation("NotificationRecipient", fields: [recipientUserId], references: [id], onDelete: Restrict)
  booking          Booking?                      @relation(fields: [bookingId], references: [id], onDelete: Restrict)
  ticket           Ticket?                       @relation(fields: [ticketId], references: [id], onDelete: Restrict)
  deliveryAttempts NotificationDeliveryAttempt[]

  @@index([status, availableAt, createdAt])
  @@index([recipientUserId, createdAt])
  @@index([bookingId])
  @@index([ticketId])
}

model NotificationDeliveryAttempt {
  id                   String                     @id @default(uuid())
  notificationOutboxId String
  provider             NotificationProviderName
  providerMessageId    String?
  status               NotificationDeliveryStatus
  attemptNumber        Int
  startedAt            DateTime                   @db.Timestamptz(3)
  completedAt          DateTime?                  @db.Timestamptz(3)
  safeErrorCode        String?
  createdAt            DateTime                   @default(now()) @db.Timestamptz(3)

  notificationOutbox NotificationOutbox @relation(fields: [notificationOutboxId], references: [id], onDelete: Restrict)

  @@unique([notificationOutboxId, attemptNumber])
  @@index([provider, status, startedAt])
}

// Transactional inventory invalidations. These rows are committed in the same
// PostgreSQL transaction as the authoritative inventory mutation. Redis is only
// a delivery transport; this outbox is the durable hand-off boundary.
model InventoryEventOutbox {
  id               String             @id @default(uuid())
  eventType        InventoryEventType
  sessionId        String
  aggregateId      String?
  payload          Json
  deduplicationKey String             @unique
  createdAt        DateTime           @default(now()) @db.Timestamptz(3)
  availableAt      DateTime           @default(now()) @db.Timestamptz(3)
  attemptCount     Int                @default(0)
  processedAt      DateTime?          @db.Timestamptz(3)
  lastError        String?
  deadLetterAt     DateTime?          @db.Timestamptz(3)

  session EventSession @relation(fields: [sessionId], references: [id], onDelete: Restrict)

  @@index([processedAt, deadLetterAt, availableAt, createdAt])
  @@index([sessionId, createdAt])
  @@index([aggregateId])
}

// Small, non-sensitive operational counters shared by the web process and
// workers. Failures to write metrics never participate in inventory decisions.
model InventoryOperationsMetric {
  id                        String    @id
  holdConflictCount         BigInt    @default(0)
  transactionRetryCount     BigInt    @default(0)
  dispatcherFailureCount    BigInt    @default(0)
  lastDispatcherDurationMs  Int?
  lastDispatcherAt          DateTime? @db.Timestamptz(3)
  lastExpirySweepDurationMs Int?
  lastExpirySweepAt         DateTime? @db.Timestamptz(3)
  lastExpiryLagMs           Int?
  updatedAt                 DateTime  @updatedAt @db.Timestamptz(3)
}

enum WorkerType {
  INVENTORY_OUTBOX_DISPATCHER
  HOLD_EXPIRY_WORKER
  REALTIME_GATEWAY
  PAYMENT_RECONCILIATION
  TICKET_ISSUANCE_DISPATCHER
  NOTIFICATION_DISPATCHER
}

enum WorkerHealthStatus {
  STARTING
  HEALTHY
  DEGRADED
  STOPPED
}

/// Phase 5C1 worker liveness. Readiness derives staleness from lastSeenAt, so a
/// crashed process becomes visible without any Redis dependency. Rows carry no
/// secret, connection string, hostname, or process command line: instanceLabel
/// is an operator-chosen non-secret identifier such as "dispatcher-1".
model WorkerHeartbeat {
  workerType          WorkerType
  environment         String             @db.VarChar(32)
  instanceLabel       String             @db.VarChar(64)
  status              WorkerHealthStatus
  version             String?            @db.VarChar(64)
  startedAt           DateTime           @db.Timestamptz(3)
  lastSeenAt          DateTime           @db.Timestamptz(3)
  lastRunDurationMs   Int?
  consecutiveFailures Int                @default(0)
  createdAt           DateTime           @default(now()) @db.Timestamptz(3)
  updatedAt           DateTime           @updatedAt @db.Timestamptz(3)

  @@id([workerType, environment, instanceLabel])
  @@index([lastSeenAt])
}
