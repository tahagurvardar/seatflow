# =============================================================================
# SeatFlow — free serverless staging environment (Phase 5C2B)
#
# TEMPLATE ONLY. Every value below is a placeholder and is rejected by
# `npm run staging:secrets -- check`.
#
#   cp .env.staging.example .env.staging.local
#
# `.env.staging.local` is gitignored and must never be committed, pasted into a
# chat, or included in a log, screenshot, or issue. Nothing in the SeatFlow
# tooling prints a value from it: reports name variables and state verdicts.
#
# This environment is a DEMO. It cannot take a real payment, and it may only
# email one approved address. See docs/phase-5c2b-free-staging.md.
# =============================================================================

# --- Which deployment this is ------------------------------------------------
# `staging-demo` is what permits the simulated payment provider. The permission
# is not granted by this flag alone: every condition in evaluateStagingDemoMode
# must hold (https vercel.app origin, no Stripe credentials, no live provider
# mode, no production-launch marker). Set it to anything else and LOCAL_SIGNED
# is refused, exactly as in production.
SEATFLOW_DEPLOYMENT_PROFILE=staging-demo

# Vercel Hobby cannot host a resident worker process, so scheduled work arrives
# as signed QStash deliveries to /api/internal/jobs/<job>.
SEATFLOW_JOB_MODE=serverless

# Optional. Only needed if staging is served from a host that is not *.vercel.app.
# SEATFLOW_STAGING_ORIGIN=https://staging.example.com

# --- Neon PostgreSQL ---------------------------------------------------------
# Two DIFFERENT endpoints. Neon marks the pooled one with a `-pooler` suffix on
# its host label, and the tooling refuses the pair if they are swapped:
#
#   DATABASE_URL  pooled  — application runtime. Serverless functions fan out,
#                           and without the pooler they exhaust Neon's limit.
#   DIRECT_URL    direct  — Prisma migrations. The pooler runs in transaction
#                           mode and cannot hold the advisory lock a migration
#                           takes, so migrations against it fail confusingly.
DATABASE_URL=postgresql://USER:PASSWORD@ep-your-endpoint-pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@ep-your-endpoint.eu-central-1.aws.neon.tech/neondb?sslmode=require

# --- Origins -----------------------------------------------------------------
# Both must be the https vercel.app URL Vercel assigns the project.
BETTER_AUTH_URL=https://your-project.vercel.app
NEXT_PUBLIC_APP_URL=https://your-project.vercel.app

# Deliberately unset. There is no Socket.IO gateway on a serverless platform,
# so clients start in authoritative polling. Setting this to a loopback URL
# would point every visitor's browser at their own machine.
# NEXT_PUBLIC_REALTIME_URL=

# --- Secrets -----------------------------------------------------------------
# Generate each one separately. Never reuse a value between variables, and never
# copy one from your local .env — a staging environment is internet-reachable.
#   openssl rand -base64 48
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
TICKET_CREDENTIAL_SECRET=replace-with-at-least-32-random-characters

# --- Payments: simulated -----------------------------------------------------
# LOCAL_SIGNED is a deterministic simulated provider. It accepts no card, moves
# no money, and contacts no payment network. The UI states this to visitors.
#
# There is no Stripe account for this project. Do not set STRIPE_* here: their
# presence alone disqualifies staging-demo mode and the deployment falls back to
# production rules, which refuse LOCAL_SIGNED outright.
PAYMENT_PROVIDER=LOCAL_SIGNED
LOCAL_PAYMENT_WEBHOOK_SECRET=replace-with-at-least-32-random-characters

# --- Email: real provider, redirected delivery -------------------------------
# RESEND_MODE=test redirects EVERY message to RESEND_TEST_RECIPIENT, whatever
# the intended recipient was. That is what makes it safe to run a real provider
# here. The intended recipient survives only as a short non-reversible digest in
# the subject, never as a live address.
#
# No custom sending domain exists, so the sender must remain an onboarding
# address on resend.dev. A display name is allowed:
#   RESEND_FROM_ADDRESS=SeatFlow <onboarding@resend.dev>
NOTIFICATION_PROVIDER=RESEND
RESEND_API_KEY=re_replace_with_your_own_key
RESEND_FROM_ADDRESS=SeatFlow <onboarding@resend.dev>
RESEND_MODE=test
RESEND_TEST_RECIPIENT=the-address-on-your-resend-account@example.com
# RESEND_REQUEST_TIMEOUT_MS=15000

# --- QStash: signed job delivery ---------------------------------------------
# Both signing keys are required. They are what authenticates a delivery to
# /api/internal/jobs/<job>; without them every delivery is rejected and
# scheduled work silently never runs. Supporting both keys is what makes
# rotation possible without a window where everything fails.
QSTASH_CURRENT_SIGNING_KEY=sig_replace_with_your_current_signing_key
QSTASH_NEXT_SIGNING_KEY=sig_replace_with_your_next_signing_key
# Publishing token. Needed only by `npm run staging:schedule`, never by a
# request path. Safe to omit from the deployed environment.
QSTASH_TOKEN=replace_with_your_qstash_token

# Optional. Defaults to NEXT_PUBLIC_APP_URL.
# SEATFLOW_INTERNAL_JOB_ORIGIN=https://your-project.vercel.app
# JOB_REQUEST_MAX_BYTES=8192
# JOB_MAX_DURATION_SECONDS=45
# JOB_CLOCK_TOLERANCE_SECONDS=15
# JOB_REPLAY_WINDOW_SECONDS=3600

# --- Upstash Redis -----------------------------------------------------------
# Optional. Without it the deployment loses realtime event delivery and
# distributed rate limiting, and falls back to polling and per-process counters.
# Neither costs correctness: PostgreSQL remains authoritative for every
# inventory, hold, payment, refund, booking, and ticket decision.
#
# REST is preferred on serverless — it holds no socket, so concurrent isolates
# cannot exhaust the free-tier connection limit. TCP is used when only REDIS_URL
# is set, and is what BullMQ needs in local development.
REDIS_URL=rediss://default:PASSWORD@your-endpoint.upstash.io:6379
UPSTASH_REDIS_REST_URL=https://your-endpoint.upstash.io
UPSTASH_REDIS_REST_TOKEN=replace_with_your_upstash_rest_token

# Namespace this environment's Redis keys. Sharing a prefix between environments
# lets them read each other's events.
REDIS_STREAM_PREFIX=seatflow:staging
REDIS_WORKER_ID=seatflow-staging

# --- Operations --------------------------------------------------------------
SEATFLOW_SERVICE_NAME=seatflow-staging
LOG_LEVEL=info
RATE_LIMIT_ENABLED=true
SECURITY_HEADERS_ENABLED=true

# Vercel terminates TLS and sets x-forwarded-for. Trusting exactly one hop means
# abuse controls see the client rather than the proxy, without letting a caller
# inject an address by prepending to the header.
TRUSTED_PROXY_MODE=trusted-hop
TRUSTED_PROXY_HOP_COUNT=1

# --- Staging seed passwords (local only) -------------------------------------
# Used by `npm run staging:seed` for synthetic demo accounts. Generate each one:
#   openssl rand -base64 24
# These are demo credentials, but they still guard an internet-reachable
# environment. Do not reuse a real password, and do not import them into Vercel.
STAGING_SEED_ADMIN_PASSWORD=replace-with-a-generated-password
STAGING_SEED_ORGANIZER_PASSWORD=replace-with-a-generated-password
STAGING_SEED_OPERATOR_PASSWORD=replace-with-a-generated-password
STAGING_SEED_CUSTOMER_PASSWORD=replace-with-a-generated-password

# =============================================================================
# Never set here. Each is rejected by `npm run staging:secrets -- check`:
#
#   STRIPE_*                        no payment account exists for this project
#   TEST_DATABASE_URL               the guarded test runner resets its target
#   SHADOW_DATABASE_URL             local migration tooling only
#   LOCAL_EMAIL_CAPTURE_DIR         writes customer content to disk
#   SEATFLOW_E2E_TEST_MODE          isolated browser-test harness only
#   SEATFLOW_PRODUCTION_LAUNCH      this is a demo, not a launch
# =============================================================================
