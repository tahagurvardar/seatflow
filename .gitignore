# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# generated database client
/src/generated/prisma

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
# The `.env*` pattern already covers .env.staging.local; the templates are the
# only environment files that may ever be tracked, and they hold placeholders.
.env*
!.env.example
!.env.staging.example
tmp/seatflow-mail/

# Phase 5C2B staging authorization marker. Its presence lets the migration
# command skip its confirmation prompt, so it is a local operator decision and
# must never be shared through the repository.
.staging-migration-authorized

# Phase 5C1 operational artifacts.
# Backups contain complete customer, payment, and ticket data; load-test and
# chaos runs produce reports that may embed references. None of this may ever
# reach version control, so the patterns are deliberately broad.
*.dump
*.sql.gz
*.backup
/backups/
/tmp/backups/
/tmp/load-test/
/tmp/chaos/
/tmp/reports/
load-test-*.json
chaos-report-*.json
accessibility-report-*.json

# Generated ticket artifacts must never be retained in the tree.
*.pdf
!public/**/*.pdf

# Structured log capture
*.log
/logs/

# Local Redis snapshot/append files. A dev Redis server writes these into its
# working directory; they are runtime state, never source.
*.rdb
*.aof
dump.rdb

# vercel
.vercel

# Editor and assistant tooling. Local developer preference, never source.
.claude/
.cursor/
.idea/
.vscode/

# typescript
*.tsbuildinfo
next-env.d.ts

# Playwright browser-verification output
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
tests/browser/.auth/
